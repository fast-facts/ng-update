{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "./src",
    "lib": [
      "ES2018",
      "dom"
    ],
    "module": "commonjs",
    "target": "ES2018",
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    "inlineSources": true,
    "noEmitHelpers": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "pretty": true,
    "sourceMap": true,
    "strict": true,
    "strictBindCallApply": false
  },
  "include": [
    "./src/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ]
}